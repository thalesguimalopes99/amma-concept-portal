{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index-central.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(?:woff2|jpg|jpeg|png|svg|webp|avif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
